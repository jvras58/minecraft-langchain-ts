// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model UserBot {
  id            String         @id @default(cuid())
  name          String         @unique
  metrics       Metric[]
  actionMetrics ActionMetric[]
}

model Metric {
  id           String   @id @default(cuid())
  userBotId    String
  timestamp    DateTime @default(now())
  provider     String
  model        String
  inputTokens  Int?
  outputTokens Int?
  responseTime Float

  gpuName  String?
  cpuName  String?
  os       String?
  taskName String?

  environment Json

  userBot UserBot @relation(fields: [userBotId], references: [id])

  @@index([userBotId, timestamp])
  @@index([provider])
  @@index([taskName])
}

model ActionMetric {
  id        String   @id @default(cuid())
  userBotId String
  timestamp DateTime @default(now())
  action    String
  direction String?
  content   String?  @db.Text

  success         Boolean
  errorMessage    String? @db.Text
  executionTimeMs Float

  userBot UserBot @relation(fields: [userBotId], references: [id])

  @@index([userBotId, timestamp])
  @@index([userBotId, action])
}
