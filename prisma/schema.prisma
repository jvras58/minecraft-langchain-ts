// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model UserBot {
  id            String         @id @default(cuid())
  name          String?
  metrics       Metric[]
  actionMetrics ActionMetric[]
}

model Metric {
  id           String   @id @default(cuid())
  userBotId    String
  timestamp    DateTime @default(now())
  provider     String
  model        String
  inputTokens  Int?
  outputTokens Int?
  responseTime Float

  gpuName String?
  cpuName String?
  os      String?

  taskName String?

  environment String

  userBot UserBot @relation(fields: [userBotId], references: [id])
}

model ActionMetric {
  id        String   @id @default(cuid())
  userBotId String
  timestamp DateTime @default(now())
  action    String
  direction String?
  content   String?

  success       Boolean @default(true)
  errorMessage  String?
  executionTime Float?

  userBot UserBot @relation(fields: [userBotId], references: [id])

  @@index([userBotId, timestamp])
  @@index([action])
}
