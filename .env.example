# Chave da API do Groq
# Obtenha em: https://console.groq.com/keys
GROQ_API_KEY=sua-chave-groq-aqui

# Configurações do Servidor Minecraft
MINECRAFT_HOST=localhost
MINECRAFT_PORT=25565
BOT_USERNAME=AgenteBot
BOT_AUTH=offline

# Configurações do LLM
LLM_PROVIDER=groq  # ou ollama

# Ollama
OLLAMA_MODEL=llama2

# LangSmith (Opcional - para métricas e tracing)
# Obtenha em: https://smith.langchain.com
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=sua-chave-langsmith-aqui
LANGCHAIN_PROJECT=minecraft-langchain